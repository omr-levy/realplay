flowchart LR
    T["POST /tournaments"]
    Bet["POST /bet"]
    LB["GET /tournaments/:id/leaderboard"]
    SJ["BullMQ snapshot job\n(fires at endsAt + grace period)"]

    PG[("Postgres\nTournament,\nTournamentResult")]
    RD[("Redis\nactive set, meta,\nleaderboard, seen-bets")]

    T -->|"insert Tournament,\nenqueue snapshot job"| PG
    T -->|"cache active set + meta"| RD
    T -.->|"delayed trigger"| SJ

    Bet -->|"match active tournaments,\ndedupe, increment score"| RD

    LB -->|"check status"| PG
    LB -->|"read live scores\n(if active/pending)"| RD
    LB -->|"read final results\n(if finalized)"| PG

    SJ -->|"read final scores"| RD
    SJ -->|"write results,\nmark finalized"| PG
    SJ -->|"remove from active set"| RD

    T ~~~ Bet ~~~ LB ~~~ SJ

    classDef tournamentNode stroke:#2563eb,stroke-width:3px
    classDef betNode stroke:#16a34a,stroke-width:3px
    classDef leaderboardNode stroke:#ea580c,stroke-width:3px
    classDef jobNode stroke:#7c3aed,stroke-width:3px
    class T tournamentNode
    class Bet betNode
    class LB leaderboardNode
    class SJ jobNode

    linkStyle 0,1,2 stroke:#2563eb,stroke-width:2px
    linkStyle 3 stroke:#16a34a,stroke-width:2px
    linkStyle 4,5,6 stroke:#ea580c,stroke-width:2px
    linkStyle 7,8,9 stroke:#7c3aed,stroke-width:2px
